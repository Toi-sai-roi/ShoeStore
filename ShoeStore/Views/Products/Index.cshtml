@model IEnumerable<Product>

@{
    ViewData["Title"] = "Quản lý sản phẩm";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">Quản lý sản phẩm</h3>
    <a asp-action="Create" class="btn btn-primary">+ Thêm sản phẩm</a>
</div>

<table class="table table-bordered table-hover align-middle">
    <thead class="table-dark text-black">
        <tr>
            <th>Ảnh</th>
            <th>Tên</th>
            <th>Giá</th>
            <th>Mô tả</th>
            <th>Danh mục</th>
            <th class="text-center">Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @if (Model == null || !Model.Any())
        {
            <tr><td colspan="6" class="text-center">Không có sản phẩm nào.</td></tr>
        }
        else
        {
            foreach (var item in Model)
            {
                <tr>
                    <td>
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img src="/images/products/@item.ImageUrl" width="60" height="60"
                                 style="object-fit:cover; border-radius:6px;" />
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </td>
                    <td>@item.Name</td>
                    <td>@item.Price.ToString("N0") đ</td>

                    <td class="text-truncate" style="max-width:200px;"
                        title="@item.Description"
                        data-bs-toggle="tooltip"
                        data-bs-placement="top">
                        @item.Description
                    </td>

                    <td>@(item.Category?.Name ?? "—")</td>

                    <td class="text-center">
                        <a asp-action="Edit" asp-route-id="@item.Id"
                           class="btn btn-sm btn-primary">Sửa</a>
                        <a href="/Variant/Manage?productId=@item.Id"
                           class="btn btn-sm btn-outline-secondary">Tùy chọn</a>
                        <a asp-action="Delete" asp-route-id="@item.Id"
                           class="btn btn-sm btn-danger">Xóa</a>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>

@section Scripts {
    <script>
        // Kích hoạt tooltip Bootstrap
        document.querySelectorAll('[data-bs-toggle="tooltip"]')
            .forEach(el => new bootstrap.Tooltip(el))
    </script>
}