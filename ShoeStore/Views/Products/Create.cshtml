@model Product

@{
    ViewData["Title"] = "Thêm sản phẩm";
}

<div class="container-lg mt-4 mb-5">
    <div class="d-flex align-items-center gap-3 mb-4 mx-auto" style="max-width:600px;">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">← Quay lại</a>
        <h4 class="mb-0 fw-semibold">Thêm sản phẩm mới</h4>
    </div>
    <div class="card shadow-sm mx-auto" style="max-width:600px;">
        <div class="card-header py-3 fw-semibold">Thông tin sản phẩm</div>
        <div class="card-body p-4">
            <form asp-action="Create" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Tên sản phẩm <span class="text-danger">*</span></label>
                    <input asp-for="Name" class="form-control" placeholder="Nhập tên sản phẩm" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Giá (VNĐ) <span class="text-danger">*</span></label>
                    <input asp-for="Price" class="form-control" placeholder="VD: 850000" />
                    <span asp-validation-for="Price" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Mô tả</label>
                    <textarea asp-for="Description" class="form-control" rows="3" placeholder="Mô tả ngắn về sản phẩm"></textarea>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Ảnh sản phẩm</label>
                    <input type="file" name="imageFile" class="form-control" accept="image/*" />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Danh mục <span class="text-danger">*</span></label>
                    <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryId"></select>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Tùy chọn (Size / Màu / Tồn kho)</label>
                    <div id="variantList">
                        <div class="d-flex gap-2 mb-2">
                            <input type="text" name="sizes" placeholder="Size" class="form-control" />
                            <input type="text" name="colors" placeholder="Màu" class="form-control" />
                            <input type="number" name="stocks" placeholder="Tồn kho" class="form-control" min="0" />
                        </div>
                    </div>
                    <button type="button" class="btn btn-outline-secondary btn-sm mt-1" onclick="addVariant()">+ Thêm tùy chọn</button>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary px-4">Thêm sản phẩm</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function addVariant() {
            const div = document.createElement('div');
            div.className = 'd-flex gap-2 mb-2';
            div.innerHTML = `
                <input type="text" name="sizes" placeholder="Size" class="form-control" />
                <input type="text" name="colors" placeholder="Màu" class="form-control" />
                <input type="number" name="stocks" placeholder="Tồn kho" class="form-control" min="0" />
            `;
            document.getElementById('variantList').appendChild(div);
        }
    </script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}