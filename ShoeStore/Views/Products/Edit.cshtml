@model ShoeStore.Models.Product

@{
    ViewData["Title"] = "Sửa sản phẩm — " + Model.Name;
}

<div class="container-lg mt-4 mb-5">

    <div class="d-flex align-items-center gap-3 mb-4">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">← Quay lại</a>
        <div>
            <h4 class="mb-0 fw-semibold">Sửa sản phẩm</h4>
            <small class="text-muted">ID: #@Model.Id</small>
        </div>
    </div>

    <div class="row g-4">

        @* ===== THÔNG TIN SẢN PHẨM ===== *@
        <div class="col-lg-6">
            <div class="card shadow-sm h-100">
                <div class="card-header py-3 fw-semibold">Thông tin sản phẩm</div>
                <div class="card-body p-4">
                    <form asp-action="Edit" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="ImageUrl" />

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-semibold">
                                Tên sản phẩm <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Name" class="form-control" placeholder="Nhập tên sản phẩm" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Price" class="form-label fw-semibold">
                                Giá (VNĐ) <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Price" class="form-control" placeholder="VD: 850000"
                                   type="number" step="1" min="0" />
                            <span asp-validation-for="Price" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-semibold">Mô tả</label>
                            <textarea asp-for="Description" class="form-control" rows="3"
                                      placeholder="Mô tả ngắn về sản phẩm"></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Ảnh sản phẩm</label>
                            @if (!string.IsNullOrEmpty(Model.ImageUrl))
                            {
                                <div class="mb-2 d-flex align-items-center gap-3">
                                    <img src="/images/products/@Model.ImageUrl"
                                         width="80" height="80"
                                         class="rounded object-fit-cover border" />
                                    <small class="text-muted">Ảnh hiện tại</small>
                                </div>
                            }
                            <input type="file" name="imageFile" class="form-control" accept="image/*" />
                            <div class="form-text">Để trống nếu không muốn đổi ảnh.</div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="CategoryId" class="form-label fw-semibold">
                                Danh mục <span class="text-danger">*</span>
                            </label>
                            <select asp-for="CategoryId" class="form-select"
                                    asp-items="ViewBag.CategoryId"></select>
                            <span asp-validation-for="CategoryId" class="text-danger small"></span>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary px-4">Lưu thay đổi</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        @* ===== BIẾN THỂ (VARIANTS) ===== *@
        <div class="col-lg-6">
            <div class="card shadow-sm">
                <div class="card-header d-flex justify-content-between align-items-center py-3">
                    <span class="fw-semibold">
                        Biến thể
                        <span class="badge bg-secondary ms-1">@Model.Variants.Count</span>
                    </span>
                    <a asp-controller="Variant" asp-action="Create"
                       asp-route-productId="@Model.Id"
                       class="btn btn-success btn-sm">+ Thêm</a>
                </div>

                @if (!Model.Variants.Any())
                {
                    <div class="card-body text-center py-4 text-muted">
                        <p class="mb-2">Chưa có biến thể nào.</p>
                        <a asp-controller="Variant" asp-action="Create"
                           asp-route-productId="@Model.Id"
                           class="btn btn-outline-success btn-sm">+ Thêm biến thể</a>
                    </div>
                }
                else
                {
                    <div class="table-responsive" style="max-height: 320px; overflow-y: auto;">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Size</th>
                                    <th>Màu</th>
                                    <th>Tồn kho</th>
                                    <th class="text-end" style="width:100px"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var v in Model.Variants)
                                {
                                    <tr>
                                        <td>
                                            <span class="badge bg-secondary fw-normal">@v.Size</span>
                                        </td>
                                        <td>@v.Color</td>
                                        <td>
                                            @if (v.Stock == 0)
                                            {
                                                <span class="badge bg-danger">Hết</span>
                                            }
                                            else if (v.Stock <= 5)
                                            {
                                                <span class="text-warning fw-semibold">@v.Stock</span>
                                            }
                                            else
                                            {
                                                <span class="text-success fw-semibold">@v.Stock</span>
                                            }
                                        </td>
                                        <td class="text-end">
                                            <a asp-controller="Variant" asp-action="Edit"
                                               asp-route-id="@v.Id"
                                               class="btn btn-outline-warning btn-sm py-0">Sửa</a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <div class="card-footer text-end py-2">
                        <a asp-controller="Variant" asp-action="Manage"
                               asp-route-productId="@Model.Id"
                               class="btn btn-outline-primary btn-sm">
                            Quản lý đầy đủ →
                        </a>
                    </div>
                }
            </div>
        </div>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
