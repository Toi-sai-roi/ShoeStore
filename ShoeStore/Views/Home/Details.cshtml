@model ShoeStore.Models.Product

@{
    ViewData["Title"] = Model.Name;
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-5">
            <img src="/images/products/@Model.ImageUrl" class="img-fluid rounded shadow" alt="@Model.Name">
        </div>
        <div class="col-md-7">
            <h2>@Model.Name</h2>
            <p class="text-muted">Danh mục: @Model.Category?.Name</p>
            <h4 class="text-danger">@Model.Price.ToString("N0") VNĐ</h4>
            <p>@Model.Description</p>

            @if (Model.Variants != null && Model.Variants.Any())
            {
                <form asp-action="AddToCart" asp-controller="Cart" method="post">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Chọn Size / Màu</label>
                        <select name="variantId" class="form-select">
                            @foreach (var v in Model.Variants)
                            {
                                if (v.Stock == 0)
                                {
                                    <option value="@v.Id" disabled>Size @v.Size - @v.Color (Hết hàng)</option>
                                }
                                else
                                {
                                    <option value="@v.Id">Size @v.Size - @v.Color (Còn: @v.Stock)</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Số lượng</label>
                        <input type="number" name="quantity" class="form-control" value="1" min="1" style="width:100px" />
                    </div>
                    <button type="submit" class="btn btn-primary">🛒 Thêm vào giỏ</button>
                </form>
            }
            else
            {
                <div class="alert alert-warning">Sản phẩm hiện đang hết hàng.</div>
            }

            <a href="/" class="btn btn-outline-secondary mt-3">← Quay lại</a>

            <!-- Đánh giá sản phẩm -->
            <div class="container mt-5">
                <h4>Đánh giá sản phẩm</h4>
                <hr />

                @if (Model.Reviews != null && Model.Reviews.Any())
                {
                    @foreach (var r in Model.Reviews.OrderByDescending(r => r.CreatedAt))
                    {
                        <div class="card mb-3 shadow-sm">
                            <div class="card-body">
                                <div class="d-flex justify-content-between">
                                    <strong>@r.User?.FullName</strong>
                                    <span class="text-muted small">@r.CreatedAt.ToString("dd/MM/yyyy")</span>
                                </div>
                                <div class="text-warning">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <span>@(i <= r.Rating ? "★" : "☆")</span>
                                    }
                                </div>
                                <p class="mb-0 mt-1">@r.Comment</p>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted">Chưa có đánh giá nào.</p>
                }

                <!-- Form gửi review -->
                @if (Context.Session.GetString("UserEmail") != null)
                {
                    <h5 class="mt-4">Gửi đánh giá của bạn</h5>
                    <form asp-action="PostReview" asp-controller="Home" method="post">
                        <input type="hidden" name="productId" value="@Model.Id" />
                        <div class="mb-3">
                            <label class="form-label">Điểm đánh giá</label>
                            <select name="rating" class="form-select" style="width:150px">
                                @for (int i = 5; i >= 1; i--)
                                {
                                    <option value="@i">@(new string('★', i))@(new string('☆', 5 - i))</option>
                                }
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Nhận xét</label>
                            <textarea name="comment" class="form-control" rows="3" placeholder="Chia sẻ cảm nhận của bạn..."></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary">Gửi đánh giá</button>
                    </form>
                }
                else
                {
                    <p class="text-muted">Bạn cần <a href="/Account/Login">đăng nhập</a> để đánh giá sản phẩm.</p>
                }
            </div>

        </div>
    </div>
</div>