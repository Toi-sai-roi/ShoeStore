@model IEnumerable<ShoeStore.Models.Product>

@{
    ViewData["Title"] = "Trang chủ";
}

<div class="container">
    <h2 class="my-4">Cửa Hàng Giày</h2>

    <!-- Thanh tìm kiếm + filter -->
    <form method="get" asp-action="Index" asp-controller="Home" class="mb-4">
        <div class="mb-4 position-relative" style="max-width: 400px;">
            <div class="input-group">
                <input type="text" id="searchInput" class="form-control"
                       placeholder="Tìm kiếm sản phẩm..." value="@ViewBag.Search" autocomplete="off" />
                <span class="input-group-text bg-white">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.099zm-5.242 1.156a5.5 5.5 0 1 1 0-11 5.5 5.5 0 0 1 0 11z" />
                    </svg>
                </span>
            </div>
            <div id="suggestionBox" class="list-group position-absolute w-100 shadow"
                 style="z-index:999; display:none; max-height:250px; overflow-y:auto;"></div>
        </div>
    </form>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-3 mb-4">
                <div class="card h-100 shadow-sm">
                    <img src="/images/products/@item.ImageUrl" class="card-img-top" alt="@item.Name" style="height:200px;object-fit:cover;">
                    <div class="card-body text-center">
                        <h5 class="card-title">@item.Name</h5>
                        <p class="text-muted small">@item.Category?.Name</p>
                        <p class="text-danger fw-bold">@item.Price.ToString("N0") VNĐ</p>
                        <a href="/Home/Details/@item.Id" class="btn btn-outline-dark btn-sm">Chi tiết</a>
                        @if (item.Variants.Any(v => v.Stock > 0))
                        {
                            <button class="btn btn-primary btn-sm"
                                    data-bs-toggle="modal"
                                    data-bs-target="#variantModal"
                                    data-product-name="@item.Name"
                                    data-variants="@System.Text.Json.JsonSerializer.Serialize(item.Variants.Select(v => new { v.Id, v.Size, v.Color, v.Stock }))">
                                Thêm vào giỏ
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-secondary btn-sm" disabled>Hết hàng</button>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Phân trang --> 
    @if (ViewBag.TotalPages > 1)
    {
        <nav class="mt-3">
            <ul class="pagination justify-content-center">
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-controller="Home"
                           asp-route-page="@i"
                           asp-route-search="@ViewBag.Search"
                           asp-route-categoryId="@ViewBag.CategoryId"
                           asp-route-sort="@ViewBag.Sort">@i</a>
                    </li>
                }
            </ul>
        </nav>
    }
</div>

<!-- Modal chọn Variant -->
<div class="modal fade" id="variantModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Chọn phân loại</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="AddToCart" asp-controller="Cart" method="post">
                <div class="modal-body">
                    <p class="fw-bold" id="modalProductName"></p>
                    <div class="mb-3">
                        <label class="form-label">Size / Màu sắc</label>
                        <select name="variantId" class="form-select" id="variantSelect"></select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Số lượng</label>
                        <input type="number" name="quantity" id="quantityInput"
                               class="form-control" value="1" min="1" />
                        <div id="qtyError" class="invalid-feedback" style="display:none;">
                            Quá số lượng tồn kho!
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary">🛒 Thêm vào giỏ</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const searchInput = document.getElementById('searchInput');
        const suggestionBox = document.getElementById('suggestionBox');
        let timer;

        searchInput.addEventListener('input', function () {
            clearTimeout(timer);
            const q = this.value.trim();

            if (q.length === 0) {
                suggestionBox.style.display = 'none';
                return;
            }

            timer = setTimeout(async () => {
                const res = await fetch(`/Home/SearchSuggestions?q=${encodeURIComponent(q)}`);
                const data = await res.json();

                if (data.length === 0) {
                    suggestionBox.style.display = 'none';
                    return;
                }

                suggestionBox.innerHTML = data.map(p => `
                    <a href="/Home/Details/${p.id}" class="list-group-item list-group-item-action d-flex align-items-center gap-2">
                        <img src="/images/products/${p.imageUrl}" style="width:40px;height:40px;object-fit:cover;border-radius:4px;">
                        <div>
                            <div class="fw-semibold">${p.name}</div>
                            <small class="text-danger">${p.price.toLocaleString('vi-VN')} VNĐ</small>
                        </div>
                    </a>
                `).join('');

                suggestionBox.style.display = 'block';
            }, 300);
        });

        // Ẩn dropdown khi click ra ngoài
        document.addEventListener('click', function (e) {
            if (!searchInput.contains(e.target)) {
                suggestionBox.style.display = 'none';
            }
        });

        const variantModal = document.getElementById('variantModal');
        variantModal.addEventListener('show.bs.modal', function (e) {
            const btn = e.relatedTarget;
            const name = btn.getAttribute('data-product-name');
            const variants = JSON.parse(btn.getAttribute('data-variants'));

            document.getElementById('modalProductName').textContent = name;

            const select = document.getElementById('variantSelect');
            select.innerHTML = '';
            variants.forEach(v => {
                const opt = document.createElement('option');
                opt.value = v.Id;
                opt.textContent = `Size ${v.Size} - ${v.Color} (Còn: ${v.Stock})`;
                if (v.Stock === 0) opt.disabled = true;
                select.appendChild(opt);
            });

            // Reset input mỗi lần mở modal
            const qtyInput = document.getElementById('quantityInput');
            qtyInput.value = 1;
            qtyInput.classList.remove('is-invalid');
            document.getElementById('qtyError').style.display = 'none';

            // Validate khi đổi số lượng
            qtyInput.oninput = function () {
                const selected = variants.find(v => v.Id == select.value);
                const max = selected?.Stock ?? 1;
                if (parseInt(this.value) > max) {
                    this.classList.add('is-invalid');
                    document.getElementById('qtyError').style.display = 'block';
                } else {
                    this.classList.remove('is-invalid');
                    document.getElementById('qtyError').style.display = 'none';
                }
            };

            // Validate lại khi đổi variant
            select.onchange = function () {
                qtyInput.dispatchEvent(new Event('input'));
            };
        });

        // Chặn submit nếu đang invalid
        document.querySelector('#variantModal form').addEventListener('submit', function (e) {
            const qtyInput = document.getElementById('quantityInput');
            if (qtyInput.classList.contains('is-invalid')) {
                e.preventDefault();
            }
        });
    </script>
}