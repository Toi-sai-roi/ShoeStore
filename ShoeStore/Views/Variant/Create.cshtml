@model ShoeStore.Models.ProductVariant

@{
    ViewData["Title"] = "Thêm Biến Thể";
    int productId = ViewBag.ProductId;
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-6 offset-md-3">
            <h2>Thêm Biến Thể Sản Phẩm</h2>
            <hr />

            <form asp-action="Create" method="post">
                <input type="hidden" asp-for="ProductId" value="@productId" />

                <div class="form-group mb-3">
                    <label asp-for="Size" class="form-label">Kích Cỡ *</label>
                    <input asp-for="Size" class="form-control" placeholder="VD: 36, 37, 38..." />
                    <span asp-validation-for="Size" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Color" class="form-label">Màu Sắc *</label>
                    <input asp-for="Color" class="form-control" placeholder="VD: Đen, Trắng, Xanh..." />
                    <span asp-validation-for="Color" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Stock" class="form-label">Tồn Kho</label>
                    <input asp-for="Stock" type="number" class="form-control" value="0" />
                    <span asp-validation-for="Stock" class="text-danger"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Lưu</button>
                    <a asp-action="Manage" asp-route-productId="@productId" class="btn btn-secondary">Hủy</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
