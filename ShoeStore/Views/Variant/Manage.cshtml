@model List<ShoeStore.Models.ProductVariant>

@{
    ViewData["Title"] = "Quản lý biến thể — " + ViewBag.ProductName;
}

<div class="container-lg mt-4 mb-5">

    <div class="d-flex align-items-center gap-3 mb-4 flex-wrap">
        <a asp-controller="Products" asp-action="Index" class="btn btn-outline-secondary btn-sm">
            ← Quay lại danh sách
        </a>
        <div>
            <h4 class="mb-0 fw-semibold">Biến thể sản phẩm</h4>
            <small class="text-muted">@ViewBag.ProductName</small>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center py-3">
            <span class="fw-semibold">Danh sách biến thể (@Model.Count)</span>
            <a asp-controller="Variant" asp-action="Create"
                   asp-route-productId="@ViewBag.ProductId"
                   class="btn btn-primary btn-sm">
                + Thêm biến thể
            </a>
        </div>

        @if (!Model.Any())
        {
            <div class="card-body text-center py-5 text-muted">
                <div style="font-size:2.5rem;">📦</div>
                <p class="mt-2 mb-3">Chưa có biến thể nào cho sản phẩm này.</p>
                <a asp-controller="Variant" asp-action="Create"
                       asp-route-productId="@ViewBag.ProductId"
                       class="btn btn-primary">
                    Thêm biến thể đầu tiên
                </a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th style="width:60px">#</th>
                            <th>Size</th>
                            <th>Màu sắc</th>
                            <th>Tồn kho</th>
                            <th style="width:160px" class="text-end">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var (v, i) in Model.Select((v, i) => (v, i)))
                        {
                            <tr>
                                <td class="text-muted">@(i + 1)</td>
                                <td>
                                    <span class="badge bg-secondary fs-6 fw-normal px-3 py-1">
                                        @v.Size
                                    </span>
                                </td>
                                <td>
                                    <span class="d-flex align-items-center gap-2">
                                        <span class="color-dot"
                                              style="width:14px;height:14px;border-radius:50%;
                                            background:@(ColorToHex(v.Color));
                                            border:1px solid #ddd;display:inline-block;">
                                        </span>
                                        @v.Color
                                    </span>
                                </td>
                                <td>
                                    @if (v.Stock == 0)
                                    {
                                        <span class="badge bg-danger">Hết hàng</span>
                                    }
                                    else if (v.Stock <= 5)
                                    {
                                        <span class="text-warning fw-semibold">@v.Stock <small class="text-muted fw-normal">(sắp hết)</small></span>
                                    }
                                    else
                                    {
                                        <span class="text-success fw-semibold">@v.Stock</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <a asp-controller="Variant" asp-action="Edit"
                                       asp-route-id="@v.Id"
                                       class="btn btn-outline-warning btn-sm">Sửa</a>
                                    <form asp-controller="Variant" asp-action="Delete"
                                          method="post" class="d-inline"
                                          onsubmit="return confirm('Xóa biến thể Size @v.Size — @v.Color?')">
                                        <input type="hidden" name="id" value="@v.Id" />
                                        <button type="submit" class="btn btn-outline-danger btn-sm">Xóa</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@{
    string ColorToHex(string colorName) => colorName.ToLower() switch
    {
        "đen" or "black" => "#1a1a1a",
        "trắng" or "white" => "#f5f5f5",
        "đỏ" or "red" => "#dc3545",
        "xanh dương" or "blue" => "#0d6efd",
        "xanh lá" or "green" => "#198754",
        "vàng" or "yellow" => "#ffc107",
        "cam" or "orange" => "#fd7e14",
        "hồng" or "pink" => "#d63384",
        "xám" or "gray" or "grey" => "#6c757d",
        "nâu" or "brown" => "#795548",
        _ => "#adb5bd"
    };
}
