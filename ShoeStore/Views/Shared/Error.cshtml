@model ErrorViewModel
@{
    ViewData["Title"] = "Lỗi hệ thống";
}

<div class="container py-5 text-center" style="min-height: 60vh; display: flex; flex-direction: column; align-items: center; justify-content: center;">
    <div style="font-size: 6rem; font-weight: 700; color: #dee2e6; line-height: 1;">500</div>
    <h2 class="mt-2 mb-3">Lỗi hệ thống</h2>
    <p class="text-muted mb-4">Máy chủ gặp sự cố không mong muốn. Vui lòng thử lại sau.</p>
    @if (Model?.ShowRequestId == true)
    {
        <p class="text-muted small mb-4">Mã lỗi: <code>@Model.RequestId</code></p>
    }
    <div class="d-flex gap-2 justify-content-center">
        <a asp-controller="Home" asp-action="Index" class="btn btn-dark px-4">Về trang chủ</a>
        <a href="javascript:history.back()" class="btn btn-outline-secondary px-4">Quay lại</a>
    </div>
</div>

