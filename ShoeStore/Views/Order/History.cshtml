@model IEnumerable<ShoeStore.Models.Order>

@{
    ViewData["Title"] = "Lịch sử đơn hàng";
}

<div class="container mt-4">
    <h3>Lịch sử đơn hàng</h3>
    <hr />

    @if (!Model.Any())
    {
        <p class="text-muted">Bạn chưa có đơn hàng nào.</p>
    }
    else
    {
        <div class="accordion" id="orderAccordion">
            @foreach (var o in Model)
            {
                var collapseId = $"order-{o.Id}";
                <div class="accordion-item mb-2 shadow-sm">

                    <h2 class="accordion-header">
                        <button class="accordion-button collapsed d-flex justify-content-between align-items-center"
                                type="button"
                                data-bs-toggle="collapse"
                                data-bs-target="#@collapseId">

                            <span>Đơn #@o.Id — @o.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>

                            <span class="badge ms-3 @(o.Status == "Delivered" ? "bg-success" :
                                o.Status == "Cancelled" ? "bg-danger" :
                                o.Status == "Confirmed" ? "bg-primary" : "bg-warning text-dark")">
                                @o.Status
                            </span>

                            <span class="ms-auto me-3 fw-bold text-end">
                                @o.TotalAmount.ToString("N0") VNĐ
                            </span>
                        </button>
                    </h2>

                    <div id="@collapseId" class="accordion-collapse collapse">
                        <div class="accordion-body p-0">
                            <table class="table table-sm mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Sản phẩm</th>
                                        <th>Size / Màu</th>
                                        <th>SL</th>
                                        <th>Đơn giá</th>
                                        <th>Thành tiền</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var d in o.OrderDetails)
                                    {
                                        <tr>
                                            <td>@d.Variant?.Product?.Name</td>
                                            <td>@d.Variant?.Size / @d.Variant?.Color</td>
                                            <td>@d.Quantity</td>
                                            <td>@d.UnitPrice.ToString("N0")</td>
                                            <td>@((d.UnitPrice * d.Quantity).ToString("N0")) VNĐ</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                </div>
            }
        </div>
    }
</div>